

# Neon - Pooled connection (for app queries)
DATABASE_URL="postgresql://neondb_owner:<password>@ep-<your-endpoint>-pooler.<region>.aws.neon.tech/neondb?sslmode=require"

# Neon - Direct connection (for migrations)
DIRECT_URL="postgresql://neondb_owner:<password>@ep-<your-endpoint>.<region>.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-a-random-string"
NEXTAUTH_URL="http://localhost:3000"