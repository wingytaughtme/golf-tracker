generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum RoundStatus {
  in_progress
  completed
  abandoned
}

enum RoundType {
  casual
  tournament
  practice
}

enum CourseType {
  public
  private
  resort
  municipal
}

enum NineType {
  front
  back
  named
}

enum CourseSource {
  seeded
  user_created
}

enum UserRole {
  admin
  user
}

enum GameType {
  skins
  nassau
  match_play
}

enum GameStatus {
  active
  completed
  cancelled
}

enum ClubType {
  driver
  wood
  hybrid
  iron
  wedge
  putter
}

enum DistanceSource {
  manual
  range_session
  on_course
}

enum LeagueStatus {
  setup
  active
  completed
  archived
}

enum SeasonStatus {
  planning
  active
  completed
}

enum MatchupStatus {
  scheduled
  in_progress
  completed
  bye
  forfeit
}

enum LeagueRole {
  commissioner
  player
}

// ============================================================================
// MODELS
// ============================================================================

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  password_hash String?   @db.VarChar(255)
  name          String?   @db.VarChar(100)
  avatar_url    String?   @db.VarChar(255)
  role          UserRole  @default(user)
  created_at    DateTime  @default(now())

  // Preferences
  track_detailed_stats Boolean @default(false)
  preferences          Json?

  // Relations
  players               Player[]
  created_players       Player[]         @relation("CreatedPlayers")
  rounds_created        Round[]
  favorite_courses      FavoriteCourse[]
  score_edits           ScoreEdit[]
  created_courses       Course[]         @relation("CreatedCourses")
  leagues_commissioned  League[]
  league_memberships    LeaguePlayer[]

  @@map("users")
}

model Player {
  id             String    @id @default(uuid()) @db.Uuid
  user_id        String?   @db.Uuid
  created_by     String?   @db.Uuid
  name           String    @db.VarChar(100)
  email          String?   @unique @db.VarChar(255)
  ghin_number    String?   @db.VarChar(20)
  home_course_id String?   @db.Uuid
  created_at     DateTime  @default(now())

  // Relations
  user               User?              @relation(fields: [user_id], references: [id], onDelete: SetNull)
  creator            User?              @relation("CreatedPlayers", fields: [created_by], references: [id], onDelete: SetNull)
  home_course        Course?            @relation(fields: [home_course_id], references: [id], onDelete: SetNull)
  round_players      RoundPlayer[]
  handicap_history   HandicapHistory[]
  club_bags          ClubBag[]
  league_memberships LeaguePlayer[]

  @@index([user_id])
  @@index([created_by])
  @@index([home_course_id])
  @@map("players")
}

model Course {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @db.VarChar(255)
  city        String       @db.VarChar(100)
  state       String       @db.VarChar(2)
  zip_code    String?      @db.VarChar(10)
  address     String?      @db.VarChar(255)
  phone       String?      @db.VarChar(20)
  website     String?      @db.VarChar(255)
  num_holes   Int          @default(18)
  course_type CourseType?
  source      CourseSource @default(seeded)
  created_by  String?      @db.Uuid
  latitude    Decimal?     @db.Decimal(10, 7)
  longitude   Decimal?     @db.Decimal(10, 7)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  // Relations
  tee_sets         TeeSet[]
  nines            Nine[]
  rounds           Round[]
  players_home     Player[]
  favorite_courses FavoriteCourse[]
  creator          User?            @relation("CreatedCourses", fields: [created_by], references: [id], onDelete: SetNull)
  leagues          League[]
  league_weeks     LeagueWeek[]

  @@index([state])
  @@index([name])
  @@index([created_by])
  @@map("courses")
}

model Nine {
  id            String   @id @default(uuid()) @db.Uuid
  course_id     String   @db.Uuid
  name          String   @db.VarChar(50)
  nine_type     NineType @default(front)
  display_order Int      @default(0)
  created_at    DateTime @default(now())

  // Relations
  course           Course          @relation(fields: [course_id], references: [id], onDelete: Cascade)
  holes            Hole[]
  tee_nine_ratings TeeNineRating[]
  round_nines      RoundNine[]

  @@unique([course_id, name])
  @@index([course_id])
  @@map("nines")
}

model TeeSet {
  id            String  @id @default(uuid()) @db.Uuid
  course_id     String  @db.Uuid
  name          String  @db.VarChar(50)
  color         String  @db.VarChar(30)
  course_rating Decimal @db.Decimal(4, 1)
  slope_rating  Int
  total_yardage Int?
  gender        String? @db.VarChar(10)

  // Relations
  course           Course          @relation(fields: [course_id], references: [id], onDelete: Cascade)
  holes            Hole[]
  rounds           Round[]
  tee_nine_ratings TeeNineRating[]
  tee_yardages     TeeHoleYardage[]

  @@index([course_id])
  @@map("tee_sets")
}

model TeeNineRating {
  id            String  @id @default(uuid()) @db.Uuid
  tee_set_id    String  @db.Uuid
  nine_id       String  @db.Uuid
  course_rating Decimal @db.Decimal(4, 1)
  slope_rating  Int

  // Relations
  tee_set TeeSet @relation(fields: [tee_set_id], references: [id], onDelete: Cascade)
  nine    Nine   @relation(fields: [nine_id], references: [id], onDelete: Cascade)

  @@unique([tee_set_id, nine_id])
  @@index([tee_set_id])
  @@index([nine_id])
  @@map("tee_nine_ratings")
}

model TeeHoleYardage {
  id         String @id @default(uuid()) @db.Uuid
  tee_set_id String @db.Uuid
  hole_id    String @db.Uuid
  yardage    Int

  // Relations
  tee_set TeeSet @relation(fields: [tee_set_id], references: [id], onDelete: Cascade)
  hole    Hole   @relation(fields: [hole_id], references: [id], onDelete: Cascade)

  @@unique([tee_set_id, hole_id])
  @@index([tee_set_id])
  @@index([hole_id])
  @@map("tee_hole_yardages")
}

model Hole {
  id             String  @id @default(uuid()) @db.Uuid
  tee_set_id     String? @db.Uuid
  nine_id        String? @db.Uuid
  hole_number    Int
  par            Int
  distance       Int     @default(0)
  handicap_index Int

  // Relations
  tee_set      TeeSet?          @relation(fields: [tee_set_id], references: [id], onDelete: Cascade)
  nine         Nine?            @relation(fields: [nine_id], references: [id], onDelete: Cascade)
  scores       Score[]
  tee_yardages TeeHoleYardage[]

  @@unique([tee_set_id, hole_number])
  @@index([tee_set_id])
  @@index([nine_id])
  @@map("holes")
}

model Round {
  id           String      @id @default(uuid()) @db.Uuid
  course_id    String      @db.Uuid
  tee_set_id   String      @db.Uuid
  created_by   String      @db.Uuid
  date_played  DateTime    @db.Date
  status       RoundStatus @default(in_progress)
  round_type   RoundType   @default(casual)
  weather      String?     @db.VarChar(50)
  temperature  Int?
  notes        String?     @db.Text
  started_at   DateTime?
  completed_at DateTime?
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  // Relations
  course           Course           @relation(fields: [course_id], references: [id], onDelete: Restrict)
  tee_set          TeeSet           @relation(fields: [tee_set_id], references: [id], onDelete: Restrict)
  creator          User             @relation(fields: [created_by], references: [id], onDelete: Restrict)
  round_players    RoundPlayer[]
  round_nines      RoundNine[]
  score_edits      ScoreEdit[]
  side_games       SideGame[]
  league_matchups_a LeagueMatchup[] @relation("MatchupRoundA")
  league_matchups_b LeagueMatchup[] @relation("MatchupRoundB")

  @@index([course_id])
  @@index([tee_set_id])
  @@index([created_by])
  @@index([date_played])
  @@index([status])
  @@map("rounds")
}

model RoundNine {
  id         String @id @default(uuid()) @db.Uuid
  round_id   String @db.Uuid
  nine_id    String @db.Uuid
  play_order Int    @default(0)

  // Relations
  round Round @relation(fields: [round_id], references: [id], onDelete: Cascade)
  nine  Nine  @relation(fields: [nine_id], references: [id], onDelete: Cascade)

  @@unique([round_id, nine_id])
  @@index([round_id])
  @@index([nine_id])
  @@map("round_nines")
}

model RoundPlayer {
  id               String   @id @default(uuid()) @db.Uuid
  round_id         String   @db.Uuid
  player_id        String   @db.Uuid
  playing_handicap Decimal? @db.Decimal(4, 1)
  gross_score      Int?
  net_score        Decimal? @db.Decimal(5, 1)
  position         Int?

  // Relations
  round              Round             @relation(fields: [round_id], references: [id], onDelete: Cascade)
  player             Player            @relation(fields: [player_id], references: [id], onDelete: Restrict)
  scores             Score[]
  side_game_results  SideGameResult[]

  @@unique([round_id, player_id])
  @@index([round_id])
  @@index([player_id])
  @@map("round_players")
}

model Score {
  id                  String   @id @default(uuid()) @db.Uuid
  round_player_id     String   @db.Uuid
  hole_id             String   @db.Uuid
  strokes             Int?
  putts               Int?
  fairway_hit         Boolean?
  green_in_regulation Boolean?
  penalties           Int      @default(0)
  sand_shots          Int      @default(0)
  notes               String?  @db.VarChar(255)

  // Relations
  round_player RoundPlayer @relation(fields: [round_player_id], references: [id], onDelete: Cascade)
  hole         Hole        @relation(fields: [hole_id], references: [id], onDelete: Restrict)
  edits        ScoreEdit[]

  @@unique([round_player_id, hole_id])
  @@index([round_player_id])
  @@index([hole_id])
  @@map("scores")
}

model HandicapHistory {
  id                  String   @id @default(uuid()) @db.Uuid
  player_id           String   @db.Uuid
  handicap_index      Decimal  @db.Decimal(4, 1)
  effective_date      DateTime @db.Date
  calculation_details Json?

  // Relations
  player Player @relation(fields: [player_id], references: [id], onDelete: Cascade)

  @@index([player_id])
  @@index([effective_date])
  @@map("handicap_history")
}

model FavoriteCourse {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  course_id  String   @db.Uuid
  created_at DateTime @default(now())

  // Relations
  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@unique([user_id, course_id])
  @@index([user_id])
  @@index([course_id])
  @@map("favorite_courses")
}

model ScoreEdit {
  id          String   @id @default(uuid()) @db.Uuid
  score_id    String   @db.Uuid
  round_id    String   @db.Uuid
  edited_by   String   @db.Uuid
  edited_at   DateTime @default(now())
  hole_number Int
  player_name String   @db.VarChar(100)
  old_strokes Int?
  new_strokes Int?
  old_putts   Int?
  new_putts   Int?
  reason      String?  @db.VarChar(255)

  // Relations
  score  Score @relation(fields: [score_id], references: [id], onDelete: Cascade)
  round  Round @relation(fields: [round_id], references: [id], onDelete: Cascade)
  editor User  @relation(fields: [edited_by], references: [id], onDelete: Restrict)

  @@index([score_id])
  @@index([round_id])
  @@index([edited_by])
  @@index([edited_at])
  @@map("score_edits")
}

// ============================================================================
// SIDE GAMES
// ============================================================================

model SideGame {
  id         String     @id @default(uuid()) @db.Uuid
  round_id   String     @db.Uuid
  game_type  GameType
  status     GameStatus @default(active)
  config     Json       // { bet_amount, carryover, gross_net, press_threshold, etc. }
  created_at DateTime   @default(now())

  // Relations
  round   Round            @relation(fields: [round_id], references: [id], onDelete: Cascade)
  results SideGameResult[]

  @@index([round_id])
  @@map("side_games")
}

model SideGameResult {
  id              String  @id @default(uuid()) @db.Uuid
  side_game_id    String  @db.Uuid
  round_player_id String  @db.Uuid
  result_data     Json    // Game-specific result data
  payout          Decimal @default(0) @db.Decimal(8, 2)

  // Relations
  side_game    SideGame    @relation(fields: [side_game_id], references: [id], onDelete: Cascade)
  round_player RoundPlayer @relation(fields: [round_player_id], references: [id], onDelete: Cascade)

  @@unique([side_game_id, round_player_id])
  @@index([side_game_id])
  @@index([round_player_id])
  @@map("side_game_results")
}

// ============================================================================
// CLUB BAG & DISTANCES
// ============================================================================

model ClubBag {
  id         String   @id @default(uuid()) @db.Uuid
  player_id  String   @db.Uuid
  name       String   @default("My Bag") @db.VarChar(100)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  player Player @relation(fields: [player_id], references: [id], onDelete: Cascade)
  clubs  Club[]

  @@index([player_id])
  @@map("club_bags")
}

model Club {
  id            String   @id @default(uuid()) @db.Uuid
  bag_id        String   @db.Uuid
  name          String   @db.VarChar(50)
  club_type     ClubType
  brand         String?  @db.VarChar(50)
  model         String?  @db.VarChar(50)
  loft          Decimal? @db.Decimal(4, 1)
  display_order Int      @default(0)
  created_at    DateTime @default(now())

  // Relations
  bag       ClubBag        @relation(fields: [bag_id], references: [id], onDelete: Cascade)
  distances ClubDistance[]

  @@index([bag_id])
  @@map("clubs")
}

model ClubDistance {
  id          String         @id @default(uuid()) @db.Uuid
  club_id     String         @db.Uuid
  distance    Int            // yards
  source      DistanceSource @default(manual)
  notes       String?        @db.VarChar(255)
  recorded_at DateTime       @default(now())

  // Relations
  club Club @relation(fields: [club_id], references: [id], onDelete: Cascade)

  @@index([club_id])
  @@map("club_distances")
}

// ============================================================================
// LEAGUE MANAGEMENT
// ============================================================================

model League {
  id              String       @id @default(uuid()) @db.Uuid
  name            String       @db.VarChar(100)
  description     String?      @db.Text
  commissioner_id String       @db.Uuid
  default_course_id String?    @db.Uuid
  invite_code     String       @unique @db.VarChar(8)
  status          LeagueStatus @default(setup)
  config          Json?        // { points_config, tiebreakers, format defaults }
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  // Relations
  commissioner  User           @relation(fields: [commissioner_id], references: [id], onDelete: Restrict)
  default_course Course?       @relation(fields: [default_course_id], references: [id], onDelete: SetNull)
  seasons       LeagueSeason[]
  players       LeaguePlayer[]

  @@index([commissioner_id])
  @@index([default_course_id])
  @@index([invite_code])
  @@map("leagues")
}

model LeagueSeason {
  id         String       @id @default(uuid()) @db.Uuid
  league_id  String       @db.Uuid
  name       String       @db.VarChar(100)
  status     SeasonStatus @default(planning)
  start_date DateTime?    @db.Date
  end_date   DateTime?    @db.Date
  config     Json?        // Season-specific config overrides
  created_at DateTime     @default(now())

  // Relations
  league    League          @relation(fields: [league_id], references: [id], onDelete: Cascade)
  weeks     LeagueWeek[]
  standings LeagueStanding[]

  @@index([league_id])
  @@map("league_seasons")
}

model LeagueWeek {
  id         String    @id @default(uuid()) @db.Uuid
  season_id  String    @db.Uuid
  week_number Int
  course_id  String?   @db.Uuid
  start_date DateTime? @db.Date
  end_date   DateTime? @db.Date
  format     String?   @db.VarChar(50) // e.g., "stroke_play", "match_play", "stableford"
  notes      String?   @db.Text

  // Relations
  season   LeagueSeason    @relation(fields: [season_id], references: [id], onDelete: Cascade)
  course   Course?         @relation(fields: [course_id], references: [id], onDelete: SetNull)
  matchups LeagueMatchup[]

  @@unique([season_id, week_number])
  @@index([season_id])
  @@index([course_id])
  @@map("league_weeks")
}

model LeagueMatchup {
  id            String        @id @default(uuid()) @db.Uuid
  week_id       String        @db.Uuid
  player_a_id   String        @db.Uuid
  player_b_id   String?       @db.Uuid // null = bye
  round_a_id    String?       @db.Uuid // linked round for player A
  round_b_id    String?       @db.Uuid // linked round for player B
  status        MatchupStatus @default(scheduled)
  result        Json?         // { winner_id, score_a, score_b, points_a, points_b }
  completed_at  DateTime?

  // Relations
  week     LeagueWeek    @relation(fields: [week_id], references: [id], onDelete: Cascade)
  player_a LeaguePlayer  @relation("MatchupPlayerA", fields: [player_a_id], references: [id], onDelete: Cascade)
  player_b LeaguePlayer? @relation("MatchupPlayerB", fields: [player_b_id], references: [id], onDelete: SetNull)
  round_a  Round?        @relation("MatchupRoundA", fields: [round_a_id], references: [id], onDelete: SetNull)
  round_b  Round?        @relation("MatchupRoundB", fields: [round_b_id], references: [id], onDelete: SetNull)

  @@index([week_id])
  @@index([player_a_id])
  @@index([player_b_id])
  @@map("league_matchups")
}

model LeaguePlayer {
  id         String     @id @default(uuid()) @db.Uuid
  league_id  String     @db.Uuid
  user_id    String     @db.Uuid
  player_id  String     @db.Uuid
  role       LeagueRole @default(player)
  joined_at  DateTime   @default(now())
  is_active  Boolean    @default(true)

  // Relations
  league           League          @relation(fields: [league_id], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  player           Player          @relation(fields: [player_id], references: [id], onDelete: Cascade)
  matchups_as_a    LeagueMatchup[] @relation("MatchupPlayerA")
  matchups_as_b    LeagueMatchup[] @relation("MatchupPlayerB")
  standings        LeagueStanding[]

  @@unique([league_id, user_id])
  @@index([league_id])
  @@index([user_id])
  @@index([player_id])
  @@map("league_players")
}

model LeagueStanding {
  id               String @id @default(uuid()) @db.Uuid
  season_id        String @db.Uuid
  league_player_id String @db.Uuid
  wins             Int    @default(0)
  losses           Int    @default(0)
  ties             Int    @default(0)
  points           Decimal @default(0) @db.Decimal(6, 1)
  scoring_avg      Decimal? @db.Decimal(5, 1)
  rounds_played    Int    @default(0)

  // Relations
  season        LeagueSeason @relation(fields: [season_id], references: [id], onDelete: Cascade)
  league_player LeaguePlayer @relation(fields: [league_player_id], references: [id], onDelete: Cascade)

  @@unique([season_id, league_player_id])
  @@index([season_id])
  @@index([league_player_id])
  @@map("league_standings")
}
